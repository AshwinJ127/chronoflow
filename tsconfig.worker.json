{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["server.ts", "src/worker.ts", "src/lib/**/*.ts", "src/workflows/**/*.ts"],
  "exclude": ["node_modules", "src/app", "src/components", "src/store", "__tests__"]
}
